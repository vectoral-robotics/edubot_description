<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="edubot">

  <!-- ================= Base Link ================= -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://edubot_description/meshes/base.stl" scale="1 1 1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0.1 0.1 0.8 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://edubot_description/meshes/base.stl" scale="1 1 1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ================= Four Mecanum Wheels ================= -->

  <!-- Front Left Wheel -->
  <link name="wheel_fl">
    <visual>
      <geometry>
        <mesh filename="package://edubot_description/meshes/wheel_fl.stl" scale="1 1 1"/>
      </geometry>
      <origin xyz="-0.088 -0.100 0.0" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0.02 0.02 0.02 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://edubot_description/meshes/wheel_fl.stl" scale="1 1 1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="wheel_fl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_fl"/>
    <origin xyz="0.088 0.100 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Front Right Wheel -->
  <link name="wheel_fr">
    <visual>
      <geometry>
        <mesh filename="package://edubot_description/meshes/wheel_fr.stl" scale="1 1 1"/>
      </geometry>
      <origin xyz="-0.088 0.100 0.0" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0.02 0.02 0.02 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://edubot_description/meshes/wheel_fr.stl" scale="1 1 1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="wheel_fr_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_fr"/>
    <origin xyz="0.088 -0.100 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Rear Left Wheel -->
  <link name="wheel_rl">
    <visual>
      <geometry>
        <mesh filename="package://edubot_description/meshes/wheel_rl.stl" scale="1 1 1"/>
      </geometry>
      <origin xyz="0.103 -0.100 0" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0.02 0.02 0.02 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://edubot_description/meshes/wheel_rl.stl" scale="1 1 1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="wheel_rl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rl"/>
    <origin xyz="-0.103 0.100 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Rear Right Wheel -->
  <link name="wheel_rr">
    <visual>
      <geometry>
        <mesh filename="package://edubot_description/meshes/wheel_rr.stl" scale="1 1 1"/>
      </geometry>
      <origin xyz="0.103 0.100 0" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0.02 0.02 0.02 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://edubot_description/meshes/wheel_rr.stl" scale="1 1 1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="wheel_rr_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rr"/>
    <origin xyz="-0.103 -0.100 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

</robot>
